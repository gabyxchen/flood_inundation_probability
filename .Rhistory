setwd("C:/Users/Gab/OneDrive/Documents/SPRING 2026/CPLN6750_Land Use and Environmental Modeling/flood_inundation_probability")
calgary <- read_csv("calgary.csv")
slc <- read_csv("slc.csv")
#check data
dim(calgary)
dim(slc)
names(calgary)
names(slc)
glimpse(calgary)
glimpse(slc)
summary(calgary$INUNAREA)
